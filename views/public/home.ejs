<!DOCTYPE html>
<html lang="en">
<head>
  <title>Social Club — Editions</title>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <section class="hero">
      <h1>Spaces built for connection.</h1>
      <p class="lead">Curated house music, curated faces. We design nights where strangers become friends. Apply below — every Edition is invite only.</p>
    </section>

    <% if (editions.length === 0) { %>
      <p class="muted">No Edition is currently open for applications. Check back soon.</p>
    <% } else { %>
      <div class="edition-grid">
        <% editions.forEach(function(edition) { %>
          <a class="edition-card" href="/edition/<%= edition.slug %>">
            <h2><%= edition.name %></h2>
            <p class="edition-meta"><%= formatDate(edition.date) %><% if (edition.location) { %> · <%= edition.location %><% } %></p>
            <% if (edition.description) { %><p class="edition-desc"><%= edition.description %></p><% } %>
            <span class="cta"><%= edition.applicationsOpen ? 'Apply now →' : 'Applications closed' %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
