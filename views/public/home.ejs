<!DOCTYPE html>
<html lang="de">
<head>
  <title>Rotraum — Editionen</title>
  <%- include('../partials/head') %>
</head>
<body>
  <%- include('../partials/header') %>
  <main class="container">
    <section class="hero">
      <h1>Willkommen in der exklusivsten Community deiner Stadt.</h1>
      <p class="lead">Rotraum ist kein Club für jeden — sondern für die Richtigen. Kuratierte Nächte, kuratierte Menschen, nur auf Einladung. Bewirb dich jetzt und sichere dir deinen Platz, bevor die nächste Edition schließt.</p>
    </section>

    <% if (editions.length === 0) { %>
      <p class="muted">Aktuell ist keine Edition für Bewerbungen offen. Schau bald wieder vorbei.</p>
    <% } else { %>
      <div class="edition-grid">
        <% editions.forEach(function(edition) { %>
          <a class="edition-card" href="/edition/<%= edition.slug %>">
            <% if (edition.photo) { %><img class="edition-card-img" src="/uploads/<%= edition.photo %>" alt=""><% } %>
            <h2><%= edition.name %></h2>
            <p class="edition-meta"><%= formatDate(edition.date) %><% if (edition.location) { %> · <%= edition.location %><% } %></p>
            <% if (edition.description) { %><p class="edition-desc"><%= edition.description %></p><% } %>
            <span class="cta"><%= edition.applicationsOpen ? 'Jetzt bewerben →' : 'Bewerbung geschlossen' %></span>
          </a>
        <% }) %>
      </div>
    <% } %>
  </main>
  <%- include('../partials/footer') %>
</body>
</html>
