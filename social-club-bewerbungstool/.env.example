# Port, auf dem der Server laeuft
PORT=3000

# Langer, zufaelliger String zum Signieren der Session-Cookies
SESSION_SECRET=change-me-to-a-long-random-string

# Zugangsdaten fuer den initialen Admin-Account
# (wird beim Start automatisch angelegt, falls noch kein Account existiert)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Optional: nur fuer Cloud-Hosting mit Persistent Disk (z. B. Render) setzen.
# Zeigt auf den dauerhaften Speicher-Ordner; dort werden uploads/ und db.json
# abgelegt, damit Fotos und Bewerbungen einen Neustart ueberleben.
# Lokal auf dem eigenen Rechner NICHT setzen.
# DATA_DIR=/var/data
